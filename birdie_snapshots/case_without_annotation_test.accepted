---
version: 1.5.4
title: case without annotation test
file: ./test/glance_typed_test.gleam
test_name: case_without_annotation_test
---
---
name: test
functions:
- name: describe
  type: "() fn(gleam.Int) -> gleam.String"
  publicity: public
  parameters:
  - type: "gleam.Int"
    name: x
  body:
  - kind: case
    type: "gleam.String"
    subjects:
    - kind: local_variable
      type: "gleam.Int"
      name: x
    clauses:
    - patterns:
      -
        - kind: int_pattern
          type: "gleam.Int"
          value: "0"
      body:
        kind: string_literal
        type: "gleam.String"
        value: zero
    - patterns:
      -
        - kind: discard_pattern
          type: "gleam.Int"
      body:
        kind: string_literal
        type: "gleam.String"
        value: other

