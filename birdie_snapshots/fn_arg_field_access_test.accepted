        type: "0"
functions:
- name: main
  type: "() fn() -> gleam.Int"
  publicity: public
  body:
  - kind: call
    type: "gleam.Int"
    function:
      kind: function
      type: "fn(test.Foo(gleam.Int), fn(test.Foo(gleam.Int)) -> gleam.Int) -> gleam.Int"
      module: test
      name: apply
    positional_arguments:
    - kind: call
      type: "test.Foo(gleam.Int)/Foo"
