        module: test
        label: value
        index: 0
- name: apply
  type: "(0, 1) fn(1, fn(1) -> 0) -> 0"
  publicity: private
  parameters:
  - type: "1"
    name: x
    annotation:
      annotation: a
      type: "1"
  - type: "fn(1) -> 0"
    name: f
    annotation:
      annotation: "fn(a) -> b"
      type: "fn(1) -> 0"
  return:
    annotation: b
    type: "0"
