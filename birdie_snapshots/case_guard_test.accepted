---
version: 1.5.4
title: case guard test
file: ./test/glance_typed_test.gleam
test_name: case_guard_test
---
---
name: test
functions:
- name: is_positive
  type: "() fn(gleam.Int) -> gleam.Bool"
  publicity: public
  parameters:
  - type: "gleam.Int"
    name: n
    annotation:
      annotation: Int
      type: "gleam.Int"
  body:
  - kind: case
    type: "gleam.Bool"
    subjects:
    - kind: local_variable
      type: "gleam.Int"
      name: n
    clauses:
    - patterns:
      -
        - kind: variable_pattern
          type: "gleam.Int"
          name: x
      guard:
        kind: binary_operator
        type: "gleam.Bool"
        name: ">"
        left:
          kind: local_variable
          type: "gleam.Int"
          name: x
        right:
          kind: int_literal
          type: "gleam.Int"
          value: "0"
      body:
        kind: function
        type: "gleam.Bool/True"
        module: gleam
        name: True
    - patterns:
      -
        - kind: discard_pattern
          type: "gleam.Int"
      body:
        kind: function
        type: "gleam.Bool/False"
        module: gleam
        name: False

