---
version: 1.5.4
title: case tuple pattern test
file: ./test/glance_typed_test.gleam
test_name: case_tuple_pattern_test
---
---
name: test
functions:
- name: swap
  type: "() fn(#(gleam.Int, gleam.Bool)) -> #(gleam.Bool, gleam.Int)"
  publicity: public
  parameters:
  - type: "#(gleam.Int, gleam.Bool)"
    name: t
    annotation:
      annotation: "#(Int, Bool)"
      type: "#(gleam.Int, gleam.Bool)"
  body:
  - kind: case
    type: "#(gleam.Bool, gleam.Int)"
    subjects:
    - kind: local_variable
      type: "#(gleam.Int, gleam.Bool)"
      name: t
    clauses:
    - patterns:
      -
        - kind: tuple_pattern
          type: "#(gleam.Int, gleam.Bool)"
          elements:
          - kind: variable_pattern
            type: "gleam.Int"
            name: n
          - kind: variable_pattern
            type: "gleam.Bool"
            name: b
      body:
        kind: tuple
        type: "#(gleam.Bool, gleam.Int)"
        elements:
        - kind: local_variable
          type: "gleam.Bool"
          name: b
        - kind: local_variable
          type: "gleam.Int"
          name: n

