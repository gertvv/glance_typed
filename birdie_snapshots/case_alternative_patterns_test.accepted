---
version: 1.5.4
title: case alternative patterns test
file: ./test/glance_typed_test.gleam
test_name: case_alternative_patterns_test
---
---
name: test
functions:
- name: f
  type: "() fn(gleam.Int) -> gleam.String"
  publicity: public
  parameters:
  - type: "gleam.Int"
    name: x
    annotation:
      annotation: Int
      type: "gleam.Int"
  body:
  - kind: case
    type: "gleam.String"
    subjects:
    - kind: local_variable
      type: "gleam.Int"
      name: x
    clauses:
    - patterns:
      -
        - kind: int_pattern
          type: "gleam.Int"
          value: "1"
      -
        - kind: int_pattern
          type: "gleam.Int"
          value: "2"
      -
        - kind: int_pattern
          type: "gleam.Int"
          value: "3"
      body:
        kind: string_literal
        type: "gleam.String"
        value: low
    - patterns:
      -
        - kind: discard_pattern
          type: "gleam.Int"
      body:
        kind: string_literal
        type: "gleam.String"
        value: other

