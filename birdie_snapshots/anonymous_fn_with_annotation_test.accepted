test_name: anonymous_fn_with_annotation_test
---
---
name: test
functions:
- name: f
  type: "() fn() -> fn(gleam.Int) -> gleam.Int"
  publicity: public
  body:
  - kind: fn
    type: "fn(gleam.Int) -> gleam.Int"
    parameters:
    - type: "gleam.Int"
      name: x
      annotation:
        annotation: Int
        type: "gleam.Int"
    return:
      annotation: Int
      type: "gleam.Int"
    body:
    - kind: local_variable
      type: "gleam.Int"
      name: x

